# ─────────────────────────────────────────────────────────────────────────────
# ETL Debug OpenEnv — Environment Variables
# Copy this file to .env and fill in your values before running inference.
#
#   cp .env.example .env
#   # edit .env
#   export $(grep -v '^#' .env | xargs)
#   python inference.py --task all
# ─────────────────────────────────────────────────────────────────────────────

# LLM API endpoint (OpenAI-compatible base URL — no trailing slash)
# Examples:
#   OpenAI:      https://api.openai.com/v1
#   Anthropic:   https://api.anthropic.com/v1
#   Together AI: https://api.together.xyz/v1
#   Local Ollama: http://localhost:11434/v1
API_BASE_URL=https://api.openai.com/v1

# Model identifier — must be available at the API_BASE_URL above
# Examples:
#   OpenAI:    gpt-4o
#   Anthropic: claude-sonnet-4-20250514
#   Together:  meta-llama/Llama-3-70b-chat-hf
MODEL_NAME=gpt-4o

# Your API key / Hugging Face token
# For OpenAI:    your sk-... key
# For Anthropic: your sk-ant-... key
# For HF:        your hf_... token
HF_TOKEN=your_api_key_here

# URL of the running environment server
# Default: local uvicorn instance
# HF Space example: https://your-username-etl-debug-openenv.hf.space
ENV_BASE_URL=http://localhost:7860